{
  "name": "tft-early-game-viewer",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "launch": "node scripts/launch-dev.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "data:sync": "tsx scripts/data-sync.ts",
    "data:validate": "tsx scripts/data-validate.ts",
    "data:scrape-live": "tsx scripts/scrape-mobalytics.ts",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder --win portable",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "playwright": "^1.51.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.1",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.0.7"
  },
  "build": {
    "appId": "com.melty.tft-early-game-viewer",
    "productName": "TFT Early Game Viewer",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!**/*.map",
      "!**/*.md",
      "!**/LICENSE*",
      "!**/CHANGELOG*"
    ],
    "directories": {
      "output": "release"
    },
    "compression": "maximum",
    "electronLanguages": ["en-US"],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": "x64"
        }
      ],
      "artifactName": "TFT-Early-Game-Viewer-${version}-portable.exe",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "TFT-Early-Game-Viewer-${version}-portable.exe"
    },
    "asar": true
  }
}
