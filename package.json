{
  "name": "tft-early-game-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "launch": "node scripts/launch-dev.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
